# Database connection string for MySQL
DATABASE_URL=user:password@tcp(localhost:3306)/blan?charset=utf8mb4&parseTime=True&loc=Local

# Secret key used to sign and verify JWT tokens
JWT_SECRET=replace_this_with_a_long_random_string

# Port the Go server listens on (default: 8080)
APP_PORT=8080

# MySQL container configuration (used by docker-compose)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=blan
MYSQL_USER=user
MYSQL_PASSWORD=password
DB_PORT=3306